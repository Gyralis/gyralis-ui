# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Public Variables
# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Public Provider(s) - Useful for testing
NEXT_PUBLIC_USE_PUBLIC_PROVIDER=true

# Alchemy: https://www.alchemy.com
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Base RPC used by browser contract reads/log scans
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Infura: https://www.infura.io
NEXT_PUBLIC_INFURA_API_KEY=

# Enables the use of production networks in the development environment
NEXT_PUBLIC_PROD_NETWORKS_DEV=false 

# Livepeer: https://livepeer.com
NEXT_PUBLIC_LIVEPEER_API_KEY=

# Website URL
NEXT_PUBLIC_SITE_URL=

# WalletConnect Project: https://cloud.walletconnect.com/
# A real value is required for wallet connections in deployed environments.
NEXT_PUBLIC_WC_PROJECT_ID=

# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Private Variables
# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
# Generate one here: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=

# MongoDB / Prisma
# Must include the database name in the URI path.
# Example: mongodb+srv://USER:PASSWORD@HOST/gyralis?retryWrites=true&w=majority
DATABASE_URL=

# Gyralis subgraph endpoint used by server-side scoring sync.
GYRALIS_SUBGRAPH_URL=

# Chain ID represented by GYRALIS_SUBGRAPH_URL.
# Example: 100 for Gnosis.
GYRALIS_SUBGRAPH_CHAIN_ID=100

# POST /api/scoring/sync is protected with NEXTAUTH_SECRET.
# Send it as a Bearer token or x-nextauth-secret header.

# Vercel cron uses this as a Bearer token for GET /api/scoring/sync.
CRON_SECRET=

# Optional scoring sync tuning.
SCORING_SYNC_BATCH_SIZE=500

# Users to be added as admins. Separate with commas. Can access the application database
# Example: "0x123,0x456"
APP_ADMINS=""

# Disco: https://docs.disco.xyz
# Request API access at https://discoxyz.typeform.com/requestapi
DISCO_API_KEY=

# Etherscan: https://docs.etherscan.io
ETHERSCAN_API_KEY=
ETHERSCAN_API_KEY_OPTIMISM=
ETHERSCAN_API_KEY_ARBITRUM=
ETHERSCAN_API_KEY_POLYGON=

# OpenAI API Key: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# Moralis API Key: https://admin.moralis.io/settings#secret-keys
MORALIS_API_KEY=

# Gitcoin Passport Scorer ID and API key: https://scorer.gitcoin.co/#/dashboard/scorer
GITCOIN_PASSPORT_SCORER_ID=
GITCOIN_PASSPORT_API_KEY=

# Gardens subgraph version (used by 1Hive membership check route)
# Example: 0.2.6
GARDENS_SUBGRAPH_VERSION=

BLOCKSCOUT_API_KEY=
BLOCKSCOUT_POINTS_BASE=


GYRALIS_SUBGRAPH_URL=

GYRALIS_SUBGRAPH_CHAIN_ID=

DATABASE_URL=